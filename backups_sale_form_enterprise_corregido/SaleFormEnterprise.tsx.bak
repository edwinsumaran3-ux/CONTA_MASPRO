import React, { useMemo, useRef, useState } from 'react';
import { Button, Field, Input, MessageBar, MessageBarBody, Text } from '@fluentui/react-components';
import {
  Add24Regular,
  Bot24Regular,
  CheckmarkCircle24Filled,
  CloudArrowUp24Regular,
  Search24Regular,
} from '@fluentui/react-icons';
import { AnimatePresence, motion } from 'framer-motion';
import { GuiaRemisionPanel } from './GuiaRemisionPanel';
import { PrintPanel } from './PrintPanel';

export type SaleFormData = {
  serie: string;
  number: string;
  customerRuc: string;
  subtotal: string;
  igv: string;
  revenueAccount: string;
  costCenter: string;
};

type RucValidationState = 'idle' | 'validating' | 'valid' | 'invalid' | 'unknown';
type SaleAccountingLineType = 'RECEIVABLE' | 'TAX' | 'REVENUE';

type SaleItem = {
  id: string;
  code: string;
  description: string;
  unit: string;
  quantity: string;
  unitPrice: string;
  lineSubtotal: string;
  accountCode: string;
  accountName: string;
  costCenter: string;
  taxTreatment: string;
};

type SaleAccountLine = {
  accountCode: string;
  accountName: string;
  costCenter: string;
  debit: string;
  credit: string;
  lineType: SaleAccountingLineType;
  taxTreatment: string;
};

type SaleInvoicePrintData = {
  serie: string;
  number: string;
  customerRuc: string;
  subtotal: string;
  igv: string;
  total: string;
  lineItems: Array<{
    productCode: string;
    description: string;
    unit: string;
    quantity: string;
    unitPrice: string;
    lineSubtotal: string;
  }>;
};

type GeminiSaleItem = {
  product_code?: string | null;
  description?: string | null;
  unit?: string | null;
  quantity?: string | number | null;
  unit_price?: string | number | null;
  line_subtotal?: string | number | null;
};

type GeminiSaleResponse = {
  status?: string;
  message?: string;
  serie?: string | null;
  number?: string | null;
  issue_date?: string | null;
  customer_ruc?: string | null;
  customer_name?: string | null;
  partner_ruc?: string | null;
  subtotal?: string | number | null;
  igv?: string | number | null;
  total?: string | number | null;
  cost_center_suggested?: string | null;
  line_items?: GeminiSaleItem[];
  confidence?: { overall?: number };
  warnings?: string[];
  compliance?: { blocked?: boolean; warnings?: string[] };
  sunat_validation?: {
    taxpayer_status?: string | null;
    taxpayer_condition?: string | null;
    source?: string | null;
  };
};

export type SaleSubmitPayload = {
  form: SaleFormData;
  customerName: string;
  issueDate: string;
  subtotal: string;
  igv: string;
  total: string;
  items: Array<Omit<SaleItem, 'id'>>;
  accountLines: SaleAccountLine[];
  auditMetadata: {
    source: 'MANUAL' | 'GEMINI';
    selectedFileName: string;
    aiWarnings: string[];
    modifyReason: string;
    modifyDetail: string;
    engineVersion: string;
  };
};

export type SaleSubmitResult = {
  id?: string;
  row_hash?: string;
  previous_hash?: string;
  total_debit?: string;
  total_credit?: string;
  diagnostics?: {
    database_url?: string;
    insert_or_update_executed?: boolean;
    commit_executed?: boolean;
    commit_confirmed?: boolean;
    select_returned_rows?: Record<string, number>;
    select_after_save?: {
      journal_entry?: {
        id?: string;
        description?: string;
        source_id?: string;
        total_debit?: string;
        total_credit?: string;
      } | null;
      financial_document?: {
        id?: string;
        series?: string;
        number?: string;
        total_amount?: string;
      } | null;
    };
  };
};

type SaleFormEnterpriseProps = {
  form: SaleFormData;
  onFormChange: (next: SaleFormData) => void;
  token?: string;
  tenantId?: string;
  onClose: () => void;
  onSubmit: (payload: SaleSubmitPayload) => Promise<SaleSubmitResult | void> | SaleSubmitResult | void;
};

const API_BASE = '/api/v1';
const DEFAULT_COST_CENTER = 'LIM-COM';
const DEFAULT_REVENUE_ACCOUNT = '7011';
const ENGINE_VERSION = 'CONTA_PRO_SALE_FORM_UI_2026_02';
const SALE_AI_TARGET_FIELDS = [
  'serie',
  'number',
  'issueDate',
  'customerRuc',
  'customerName',
  'lineItems',
  'subtotal',
  'igv',
  'total',
  'costCenter',
];

const toNumber = (value: string | number | undefined | null) => {
  if (typeof value === 'number') return Number.isFinite(value) ? value : 0;
  const raw = String(value ?? '0').replace(/[^0-9,.\-]/g, '');
  const normalized = raw.includes(',') && !raw.includes('.') ? raw.replace(',', '.') : raw.replace(/,/g, '');
  const parsed = Number.parseFloat(normalized);
  return Number.isFinite(parsed) ? parsed : 0;
};

const money = (value: number) => value.toFixed(2);

const newId = () => {
  if (typeof crypto !== 'undefined' && 'randomUUID' in crypto) return crypto.randomUUID();
  return `${Date.now()}-${Math.random()}`;
};

const normalizeAccount = (value?: string) => String(value || '').replace(/\D/g, '').slice(0, 10);

const normalizeCostCenter = (value?: string) => {
  const clean = String(value || DEFAULT_COST_CENTER).trim().toUpperCase().replace(/\s+/g, '-');
  return clean || DEFAULT_COST_CENTER;
};

const defaultSaleForm = (serie = 'F001'): SaleFormData => ({
  serie,
  number: '',
  customerRuc: '',
  subtotal: '0.00',
  igv: '0.00',
  revenueAccount: DEFAULT_REVENUE_ACCOUNT,
  costCenter: DEFAULT_COST_CENTER,
});

const createItem = (form: SaleFormData): SaleItem => ({
  id: newId(),
  code: '',
  description: 'Venta de mercaderia o servicio',
  unit: 'UND',
  quantity: '1.00',
  unitPrice: money(toNumber(form.subtotal)),
  lineSubtotal: money(toNumber(form.subtotal)),
  accountCode: normalizeAccount(form.revenueAccount) || DEFAULT_REVENUE_ACCOUNT,
  accountName: 'Ventas',
  costCenter: normalizeCostCenter(form.costCenter),
  taxTreatment: 'Ingreso gravado con IGV segun comprobante emitido',
});

const toSaleItem = (item: GeminiSaleItem, form: SaleFormData): SaleItem => {
  const quantity = money(toNumber(item.quantity || '1.00'));
  const unitPrice = money(toNumber(item.unit_price || '0.00'));
  const lineSubtotal = money(toNumber(item.line_subtotal || toNumber(quantity) * toNumber(unitPrice)));
  return {
    id: newId(),
    code: String(item.product_code || ''),
    description: String(item.description || ''),
    unit: String(item.unit || 'UND'),
    quantity,
    unitPrice,
    lineSubtotal,
    accountCode: normalizeAccount(form.revenueAccount) || DEFAULT_REVENUE_ACCOUNT,
    accountName: 'Ventas',
    costCenter: normalizeCostCenter(form.costCenter),
    taxTreatment: 'Ingreso gravado con IGV segun comprobante emitido',
  };
};

export const SaleFormEnterprise = ({ form, onFormChange, token, tenantId, onClose, onSubmit }: SaleFormEnterpriseProps) => {
  const fileInputRef = useRef<HTMLInputElement | null>(null);
  const [items, setItems] = useState<SaleItem[]>(() => [createItem(form)]);
  const [customerName, setCustomerName] = useState('');
  const [issueDate, setIssueDate] = useState(() => new Date().toISOString().slice(0, 10));
  const [isAutoIgv, setIsAutoIgv] = useState(true);
  const [isPosting, setIsPosting] = useState(false);
  const [isReadingAi, setIsReadingAi] = useState(false);
  const [selectedFileName, setSelectedFileName] = useState('');
  const [rucState, setRucState] = useState<RucValidationState>('idle');
  const [rucMessage, setRucMessage] = useState('Pendiente de validacion externa');
  const [status, setStatus] = useState('');
  const [aiWarnings, setAiWarnings] = useState<string[]>([]);
  const [showSuccess, setShowSuccess] = useState(false);
  const [showGuide, setShowGuide] = useState(false);
  const [printInvoice, setPrintInvoice] = useState<SaleInvoicePrintData | null>(null);

  const subtotal = toNumber(form.subtotal);
  const igv = toNumber(form.igv);
  const total = subtotal + igv;

  const itemsSubtotal = useMemo(
    () => items.reduce((acc, item) => acc + toNumber(item.lineSubtotal), 0),
    [items],
  );

  const accountingLines = useMemo<SaleAccountLine[]>(() => {
    const revenueAccount = normalizeAccount(form.revenueAccount) || DEFAULT_REVENUE_ACCOUNT;
    const lines: SaleAccountLine[] = [
      {
        accountCode: '1212',
        accountName: 'Cuentas por cobrar comerciales',
        costCenter: normalizeCostCenter(form.costCenter),
        debit: money(total),
        credit: '0.00',
        lineType: 'RECEIVABLE',
        taxTreatment: 'Derecho de cobro por factura emitida',
      },
      {
        accountCode: '4011',
        accountName: 'IGV por pagar',
        costCenter: '-',
        debit: '0.00',
        credit: money(igv),
        lineType: 'TAX',
        taxTreatment: 'Debito fiscal por venta gravada',
      },
      {
        accountCode: revenueAccount,
        accountName: revenueAccount === '704101' ? 'Prestacion de servicios' : 'Ventas',
        costCenter: normalizeCostCenter(form.costCenter),
        debit: '0.00',
        credit: money(subtotal),
        lineType: 'REVENUE',
        taxTreatment: 'Ingreso devengado por comprobante de venta',
      },
    ];
    return lines.filter((line) => toNumber(line.debit) !== 0 || toNumber(line.credit) !== 0);
  }, [form.costCenter, form.revenueAccount, igv, subtotal, total]);

  const lineItemsForOutput = (sourceItems = items) => sourceItems.map((item) => ({
    productCode: item.code,
    description: item.description,
    unit: item.unit,
    quantity: item.quantity,
    unitPrice: item.unitPrice,
    lineSubtotal: item.lineSubtotal,
  }));

  const updateFormAmountsFromItems = (nextItems: SaleItem[]) => {
    const nextSubtotal = nextItems.reduce((acc, item) => acc + toNumber(item.lineSubtotal), 0);
    onFormChange({
      ...form,
      subtotal: money(nextSubtotal),
      igv: isAutoIgv ? money(nextSubtotal * 0.18) : form.igv,
    });
  };

  const updateField = (key: keyof SaleFormData, value: string) => {
    const next: SaleFormData = { ...form, [key]: value };
    if (key === 'subtotal' && isAutoIgv) {
      next.igv = money(toNumber(value) * 0.18);
    }
    if (key === 'subtotal') {
      setItems((prev) => {
        if (prev.length !== 1) return prev;
        return prev.map((item) => ({
          ...item,
          unitPrice: money(toNumber(value)),
          lineSubtotal: money(toNumber(value)),
        }));
      });
    }
    if (key === 'costCenter') {
      const nextCostCenter = normalizeCostCenter(value);
      setItems((prev) => prev.map((item) => ({ ...item, costCenter: nextCostCenter })));
    }
    if (key === 'revenueAccount') {
      const nextAccount = normalizeAccount(value);
      setItems((prev) => prev.map((item) => ({ ...item, accountCode: nextAccount || DEFAULT_REVENUE_ACCOUNT })));
    }
    onFormChange(next);
  };

  const updateItem = (id: string, key: keyof SaleItem, value: string) => {
    setItems((prev) => {
      const next = prev.map((item) => {
        if (item.id !== id) return item;
        const updated = { ...item, [key]: value };
        if (key === 'quantity' || key === 'unitPrice') {
          updated.lineSubtotal = money(toNumber(updated.quantity) * toNumber(updated.unitPrice));
        }
        return updated;
      });
      updateFormAmountsFromItems(next);
      return next;
    });
  };

  const addItem = () => {
    setItems((prev) => {
      const next = [
        ...prev,
        {
          ...createItem({ ...form, subtotal: '0.00' }),
          description: '',
          unitPrice: '0.00',
          lineSubtotal: '0.00',
        },
      ];
      updateFormAmountsFromItems(next);
      return next;
    });
  };

  const removeItem = (id: string) => {
    setItems((prev) => {
      if (prev.length <= 1) return prev;
      const next = prev.filter((item) => item.id !== id);
      updateFormAmountsFromItems(next);
      return next;
    });
  };

  const resolveToken = async () => {
    if (token) return token;
    const currentTenantId = tenantId || localStorage.getItem('tenant_id') || '11111111-1111-1111-1111-111111111111';
    const response = await fetch(`${API_BASE}/auth/dev-token`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tenant_id: currentTenantId, user_id: 'erp.operator', role: 'ADMIN' }),
    });
    if (!response.ok) throw new Error(await response.text());
    const payload = await response.json();
    return payload.access_token as string;
  };

  const applyGeminiPayload = (payload: GeminiSaleResponse) => {
    if (payload.status === 'configuration_required') {
      setStatus(payload.message || 'Configura GEMINI_API_KEY para activar la lectura visual.');
      return;
    }
    if (payload.status && payload.status !== 'ok') {
      setStatus('No se extrajeron datos de la factura de venta.');
      return;
    }

    const nextForm: SaleFormData = {
      ...form,
      serie: String(payload.serie || form.serie || 'F001'),
      number: String(payload.number || form.number || ''),
      customerRuc: String(payload.customer_ruc || payload.partner_ruc || form.customerRuc || ''),
      subtotal: money(toNumber(payload.subtotal)),
      igv: money(toNumber(payload.igv)),
      revenueAccount: normalizeAccount(form.revenueAccount) || DEFAULT_REVENUE_ACCOUNT,
      costCenter: normalizeCostCenter(payload.cost_center_suggested || form.costCenter),
    };

    const mappedItems = Array.isArray(payload.line_items) && payload.line_items.length > 0
      ? payload.line_items.map((item) => toSaleItem(item, nextForm))
      : [createItem(nextForm)];

    const subtotalFromItems = mappedItems.reduce((acc, item) => acc + toNumber(item.lineSubtotal), 0);
    if (toNumber(nextForm.subtotal) <= 0 && subtotalFromItems > 0) {
      nextForm.subtotal = money(subtotalFromItems);
    }
    if (toNumber(nextForm.igv) <= 0 && toNumber(nextForm.subtotal) > 0) {
      nextForm.igv = money(toNumber(nextForm.subtotal) * 0.18);
    }

    onFormChange(nextForm);
    setItems(mappedItems);
    setIssueDate(String(payload.issue_date || issueDate));
    setCustomerName(String(payload.customer_name || customerName));
    setIsAutoIgv(false);
    setAiWarnings([...(payload.warnings || []), ...(payload.compliance?.warnings || [])]);

    if (payload.compliance?.blocked) {
      setRucState('invalid');
      setRucMessage('SUNAT alerta: cliente no apto para persistencia automatica.');
    } else if (payload.sunat_validation?.source && !['not_configured', 'unavailable'].includes(payload.sunat_validation.source)) {
      setRucState('valid');
      setRucMessage(`SUNAT: ${payload.sunat_validation.taxpayer_status || 'sin estado'} / ${payload.sunat_validation.taxpayer_condition || 'sin condicion'}`);
    } else {
      setRucState('unknown');
      setRucMessage('SUNAT no configurado o no disponible; revisar datos antes de guardar.');
    }

    const confidence = Math.round(((payload.confidence?.overall || 0) as number) * 100);
    setStatus(`Factura leida con IA${confidence ? ` (${confidence}% confianza)` : ''}. Revisa datos, cuenta y centro de costo antes de guardar.`);
  };

  const readInvoiceWithGemini = async (file: File) => {
    setIsReadingAi(true);
    setSelectedFileName(file.name);
    setStatus('Leyendo factura de venta con IA...');
    setAiWarnings([]);

    try {
      const currentTenantId = tenantId || localStorage.getItem('tenant_id') || '11111111-1111-1111-1111-111111111111';
      const currentToken = await resolveToken();
      const formData = new FormData();
      formData.append('file', file);
      const targetFields = encodeURIComponent(JSON.stringify(SALE_AI_TARGET_FIELDS));
      const response = await fetch(`${API_BASE}/ai/extract-invoice?direction=sale&target_fields=${targetFields}`, {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${currentToken}`,
          'X-Tenant-Id': currentTenantId,
        },
        body: formData,
      });
      if (!response.ok) throw new Error(await response.text());
      applyGeminiPayload(await response.json());
    } catch (error) {
      setStatus(`No se pudo leer con IA. ${error instanceof Error ? error.message : 'Error desconocido'}`);
    } finally {
      setIsReadingAi(false);
    }
  };

  const validateRucExternally = async () => {
    if (!/^\d{11}$/.test(form.customerRuc)) {
      setRucState('invalid');
      setRucMessage('RUC invalido: debe tener 11 digitos.');
      return;
    }

    setRucState('validating');
    setRucMessage('Consultando servicio externo...');

    try {
      const response = await fetch(`https://api.apis.net.pe/v2/sunat/ruc?numero=${form.customerRuc}`, {
        method: 'GET',
      });
      if (response.ok) {
        const data = await response.json();
        setCustomerName(data.razonSocial || data.nombre || customerName);
        setRucState('valid');
        setRucMessage('RUC validado. Razon social cargada si el servicio la devolvio.');
        return;
      }
      setRucState('unknown');
      setRucMessage('Servicio externo no disponible. Continuar con validacion local.');
    } catch {
      setRucState('unknown');
      setRucMessage('No se pudo validar externamente. Verifica red/CORS.');
    }
  };

  const validateBeforeSubmit = () => {
    if (!form.serie.trim()) return 'Falta serie.';
    if (!form.number.trim()) return 'Falta numero.';
    if (!issueDate.trim()) return 'Falta fecha.';
    if (!/^\d{11}$/.test(form.customerRuc)) return 'RUC cliente invalido.';
    if (total <= 0) return 'Total invalido.';
    if (items.length === 0) return 'Agrega al menos un item.';
    if (accountingLines.length < 2) return 'Asiento sugerido incompleto.';
    const totalDebit = accountingLines.reduce((acc, line) => acc + toNumber(line.debit), 0);
    const totalCredit = accountingLines.reduce((acc, line) => acc + toNumber(line.credit), 0);
    if (Math.abs(totalDebit - totalCredit) > 0.01) {
      return `Asiento descuadrado: Debe ${money(totalDebit)} != Haber ${money(totalCredit)}.`;
    }
    return '';
  };

  const clearForNewSale = (nextStatus?: string) => {
    const statusAfterReset = typeof nextStatus === 'string' ? nextStatus : '';
    const nextForm = defaultSaleForm(form.serie || 'F001');
    onFormChange(nextForm);
    setItems([createItem(nextForm)]);
    setCustomerName('');
    setIssueDate(new Date().toISOString().slice(0, 10));
    setIsAutoIgv(true);
    setSelectedFileName('');
    setStatus(statusAfterReset);
    setAiWarnings([]);
    setRucState('idle');
    setRucMessage('Pendiente de validacion externa');
    setShowSuccess(Boolean(statusAfterReset));
    setShowGuide(false);
    setPrintInvoice(null);
    if (fileInputRef.current) fileInputRef.current.value = '';
  };

  const buildPersistenceMessage = (result: SaleSubmitResult | void, serie: string, number: string) => {
    const diagnostics = result?.diagnostics;
    if (!diagnostics) {
      return `Venta ${serie}-${number} guardada. Formulario limpio para nueva venta.`;
    }

    const selectEntry = diagnostics.select_after_save?.journal_entry;
    const selectDocument = diagnostics.select_after_save?.financial_document;
    const selectLabel = selectEntry?.description
      || (selectDocument ? `${selectDocument.series}-${selectDocument.number}` : 'sin filas devueltas');
    const commitLabel = diagnostics.commit_confirmed ? 'OK' : 'no confirmado';
    const dbLabel = diagnostics.database_url ? ` BD: ${diagnostics.database_url}.` : '';

    return `Venta ${serie}-${number} guardada. Commit: ${commitLabel}. SELECT: ${selectLabel}.${dbLabel} Formulario limpio para nueva venta.`;
  };

  const handleSubmit = async () => {
    const error = validateBeforeSubmit();
    if (error) {
      setStatus(error);
      return;
    }

    const nextForm: SaleFormData = {
      ...form,
      subtotal: money(subtotal),
      igv: money(igv),
      revenueAccount: normalizeAccount(form.revenueAccount) || DEFAULT_REVENUE_ACCOUNT,
      costCenter: normalizeCostCenter(form.costCenter),
    };

    const submitPayload: SaleSubmitPayload = {
      form: nextForm,
      customerName,
      issueDate,
      subtotal: money(subtotal),
      igv: money(igv),
      total: money(total),
      items: items.map(({ id, ...item }) => ({
        ...item,
        accountCode: normalizeAccount(item.accountCode) || nextForm.revenueAccount,
        costCenter: normalizeCostCenter(item.costCenter || nextForm.costCenter),
      })),
      accountLines: accountingLines,
      auditMetadata: {
        source: selectedFileName ? 'GEMINI' : 'MANUAL',
        selectedFileName,
        aiWarnings,
        modifyReason: '',
        modifyDetail: '',
        engineVersion: ENGINE_VERSION,
      },
    };

    onFormChange(nextForm);
    setIsPosting(true);

    try {
      const submitResult = await onSubmit(submitPayload);
      console.info('CONTA_PRO venta diagnostico persistencia:', submitResult?.diagnostics ?? submitResult ?? 'sin diagnostico backend');
      clearForNewSale(buildPersistenceMessage(submitResult, nextForm.serie, nextForm.number));
    } catch (submitError) {
      setStatus(
        `No se pudo guardar la venta. ${
          submitError instanceof Error ? submitError.message : 'Error desconocido'
        }`
      );
    } finally {
      setIsPosting(false);
    }
  };

  if (printInvoice) {
    return (
      <div className="sheet-form" style={{ display: 'grid', gap: 14, maxHeight: '82vh', overflowY: 'auto', paddingRight: 6 }}>
        <MessageBar intent="success">
          <MessageBarBody>
            Venta {printInvoice.serie}-{printInvoice.number} guardada en libros contables. Selecciona impresora o continua con una nueva venta.
          </MessageBarBody>
        </MessageBar>
        <PrintPanel
          token={token}
          tenantId={tenantId}
          invoiceData={printInvoice}
          onClose={clearForNewSale}
        />
        <div className="sheet-footer" style={{ position: 'static', borderTop: 'none', padding: 0, marginTop: 8 }}>
          <Button appearance="secondary" onClick={() => setPrintInvoice(null)}>Volver a la factura</Button>
          <button type="button" className="btn-fluent-primary" onClick={() => clearForNewSale()}>
            Nueva venta
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="sheet-form pro-form pro-sale-form">
      <div className="pro-form-header">
        <div>
          <Text weight="semibold">Boleta / Factura de Venta</Text>
          <p>Motor experto contable, tributario, SUNAT y lectura visual con IA.</p>
        </div>
        <div className="pro-header-actions">
          <Button appearance="secondary" onClick={() => setShowGuide(true)}>Guia transportista</Button>
          <span>AR / Registro de Ventas</span>
        </div>
      </div>

      <div className="pro-form-grid three">
        <Field label="Serie"><Input value={form.serie} onChange={(_, data) => updateField('serie', data.value)} /></Field>
        <Field label="Numero"><Input value={form.number} onChange={(_, data) => updateField('number', data.value)} /></Field>
        <Field label="Fecha"><Input type="date" value={issueDate} onChange={(_, data) => setIssueDate(data.value)} /></Field>
      </div>

      <div className="pro-upload-card">
        <Text weight="semibold">Adjuntar factura / OCR Gemini</Text>
        <input
          ref={fileInputRef}
          type="file"
          accept="image/*,.pdf,application/pdf"
          style={{ display: 'none' }}
          onChange={(event) => {
            const file = event.target.files?.[0];
            if (file) void readInvoiceWithGemini(file);
          }}
        />
        <div className="pro-upload-actions">
          <button className="btn-fluent-primary" type="button" onClick={() => fileInputRef.current?.click()} disabled={isReadingAi}>
            <CloudArrowUp24Regular />
            {isReadingAi ? 'Leyendo con IA...' : 'Adjuntar imagen/PDF y leer con IA'}
          </button>
          {selectedFileName && <span>{selectedFileName}</span>}
        </div>
        <div className="pro-help-text">
          Gemini extrae serie, numero, cliente, fecha, importes y detalle visual de la factura.
        </div>
      </div>

      <div className="pro-metric-panel">
        <div className="pro-metric-grid">
          <div>
            <Text size={200}>Base imponible</Text>
            <strong>S/ {money(subtotal)}</strong>
          </div>
          <div>
            <Text size={200}>IGV debito fiscal</Text>
            <strong>S/ {money(igv)}</strong>
          </div>
          <div>
            <Text size={200}>Total comprobante</Text>
            <strong>S/ {money(total)}</strong>
          </div>
        </div>
      </div>

      <div className="pro-form-grid customer">
        <Field label="RUC cliente">
          <Input value={form.customerRuc} onChange={(_, data) => updateField('customerRuc', data.value)} contentAfter={<Search24Regular />} />
        </Field>
        <Field label="Razon social cliente">
          <Input value={customerName} onChange={(_, data) => setCustomerName(data.value)} />
        </Field>
      </div>

      <div className="pro-validation-row">
        <Button appearance="secondary" onClick={validateRucExternally}>Validar RUC Externo</Button>
        <MessageBar intent={rucState === 'valid' ? 'success' : rucState === 'invalid' ? 'error' : 'info'}>
          <MessageBarBody>{rucMessage}</MessageBarBody>
        </MessageBar>
      </div>

      {aiWarnings.length > 0 && (
        <MessageBar intent="warning">
          <MessageBarBody>{aiWarnings.join(' | ')}</MessageBarBody>
        </MessageBar>
      )}

      <section className="dashboard-card pro-section">
        <div className="pro-section-header">
          <Text weight="semibold">Detalle de Factura - Ventas</Text>
          <button className="btn-fluent-primary" type="button" onClick={addItem}>
            <Add24Regular />
            Agregar producto
          </button>
        </div>

        <div className="pro-table-wrap">
          <table className="erp-table pro-input-table">
            <thead>
              <tr>
                <th>Codigo</th>
                <th>Descripcion</th>
                <th>Unidad</th>
                <th>Cant.</th>
                <th>P. Unit.</th>
                <th>Subtotal</th>
                <th>Cuenta</th>
                <th>Nombre cuenta</th>
                <th>Centro costo</th>
                <th>Criterio SUNAT</th>
                <th>Acc.</th>
              </tr>
            </thead>
            <tbody>
              {items.map((item) => (
                <tr key={item.id}>
                  <td><input value={item.code} onChange={(event) => updateItem(item.id, 'code', event.target.value)} style={{ width: 80 }} /></td>
                  <td><input value={item.description} onChange={(event) => updateItem(item.id, 'description', event.target.value)} style={{ width: 220 }} /></td>
                  <td><input value={item.unit} onChange={(event) => updateItem(item.id, 'unit', event.target.value)} style={{ width: 60 }} /></td>
                  <td><input value={item.quantity} onChange={(event) => updateItem(item.id, 'quantity', event.target.value)} style={{ width: 70, textAlign: 'right' }} /></td>
                  <td><input value={item.unitPrice} onChange={(event) => updateItem(item.id, 'unitPrice', event.target.value)} style={{ width: 85, textAlign: 'right' }} /></td>
                  <td><input value={item.lineSubtotal} disabled style={{ width: 85, textAlign: 'right', fontWeight: 700, color: '#1d4ed8' }} /></td>
                  <td><input value={item.accountCode} onChange={(event) => updateItem(item.id, 'accountCode', event.target.value)} style={{ width: 80 }} /></td>
                  <td><input value={item.accountName} onChange={(event) => updateItem(item.id, 'accountName', event.target.value)} style={{ width: 160 }} /></td>
                  <td><input value={item.costCenter} onChange={(event) => updateItem(item.id, 'costCenter', event.target.value)} style={{ width: 90 }} /></td>
                  <td><input value={item.taxTreatment} onChange={(event) => updateItem(item.id, 'taxTreatment', event.target.value)} style={{ width: 220 }} /></td>
                  <td><Button appearance="secondary" onClick={() => removeItem(item.id)} disabled={items.length <= 1}>X</Button></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div className="pro-section-total">
          Subtotal items: S/ {money(itemsSubtotal)}
        </div>
      </section>

      <section className="dashboard-card pro-section">
        <Text weight="semibold">Asiento contable sugerido</Text>
        <table className="erp-table pro-ledger-table">
          <thead><tr><th>Cuenta</th><th>Descripcion</th><th>Centro costo</th><th>Debe</th><th>Haber</th></tr></thead>
          <tbody>
            {accountingLines.map((line, index) => (
              <tr key={`${line.accountCode}-${line.lineType}-${index}`}>
                <td>{line.accountCode}</td>
                <td>{line.accountName}</td>
                <td>{line.costCenter}</td>
                <td style={{ textAlign: 'right' }}>{line.debit}</td>
                <td style={{ textAlign: 'right' }}>{line.credit}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <div className="pro-form-grid four">
        <Field label="Cuenta ingreso"><Input value={form.revenueAccount} onChange={(_, data) => updateField('revenueAccount', data.value)} /></Field>
        <Field label="Centro costo general"><Input value={form.costCenter} onChange={(_, data) => updateField('costCenter', data.value)} /></Field>
        <Field label="Subtotal"><Input value={money(subtotal)} onChange={(_, data) => updateField('subtotal', data.value)} /></Field>
        <Field label="IGV"><Input value={money(igv)} disabled={isAutoIgv} onChange={(_, data) => updateField('igv', data.value)} /></Field>
      </div>

      <label className="pro-checkline">
        <input
          type="checkbox"
          checked={isAutoIgv}
          onChange={(event) => {
            const checked = event.target.checked;
            setIsAutoIgv(checked);
            if (checked) onFormChange({ ...form, igv: money(subtotal * 0.18) });
          }}
        />
        IGV auto-calculado 18%
      </label>

      <div className="pro-total-banner">
        <span>Total a cobrar</span>
        <strong>S/ {money(total)}</strong>
      </div>

      {status && (
        <MessageBar intent={status.includes('No se pudo') || status.includes('Falta') || status.includes('invalido') || status.includes('descuadrado') ? 'error' : 'success'}>
          <MessageBarBody>{status}</MessageBarBody>
        </MessageBar>
      )}

      <AnimatePresence>
        {showSuccess && (
          <motion.div
            initial={{ opacity: 0, scale: 0.86 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.86 }}
            style={{
              display: 'flex',
              alignItems: 'center',
              gap: 8,
              padding: '8px 10px',
              border: '1px solid #bbf7d0',
              background: '#f0fdf4',
              borderRadius: 6,
            }}
          >
            <CheckmarkCircle24Filled primaryFill="#16a34a" />
            <span style={{ fontSize: 12, fontWeight: 600, color: '#166534' }}>Venta posteada con exito</span>
          </motion.div>
        )}
      </AnimatePresence>

      <div className="sheet-footer pro-action-bar">
        <Button appearance="secondary" onClick={onClose}>Cancelar</Button>
        <Button appearance="secondary" icon={<Bot24Regular />} onClick={() => fileInputRef.current?.click()} disabled={isReadingAi}>
          Adjuntar archivo
        </Button>
        <button type="button" className="btn-fluent-primary" onClick={handleSubmit} disabled={isPosting}>
          {isPosting ? 'Posteando...' : 'Guardar y Postear'}
        </button>
      </div>

      {showGuide && (
        <GuiaRemisionPanel
          token={token}
          tenantId={tenantId}
          source={{
            serie: form.serie,
            number: form.number,
            issueDate,
            partnerRuc: form.customerRuc,
            lineItems: lineItemsForOutput(),
          }}
          onClose={() => setShowGuide(false)}
          onSaved={() => setStatus('Guia de transportista guardada para la venta.')}
        />
      )}
    </div>
  );
};
