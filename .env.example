# ============================================================
#  CONTA_PRO Enterprise — Variables de entorno
#  Copiar este archivo como .env y completar con valores reales
#  NUNCA subir .env a git
# ============================================================

# ── Aplicación ───────────────────────────────────────────────
APP_NAME=CONTA_PRO Enterprise
APP_ENV=development

# ── Base de datos ─────────────────────────────────────────────
# Railway provee DATABASE_URL automáticamente al conectar PostgreSQL
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/contapro

# ── Redis (opcional) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Seguridad JWT ─────────────────────────────────────────────
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
LEDGER_HMAC_SECRET=cambia-esto-minimo-32-caracteres
ACCESS_TOKEN_MINUTES=480
REFRESH_TOKEN_DAYS=30

# ── CORS ─────────────────────────────────────────────────────
# Producción: agregar tu dominio Vercel
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://TU-APP.vercel.app

# ── IA — Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── IA — Claude (opcional) ───────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── SUNAT ────────────────────────────────────────────────────
SUNAT_ENDPOINT=
SUNAT_OSE_ENDPOINT=
SUNAT_PSE_ENDPOINT=
SUNAT_RUC_LOOKUP_URL=
SUNAT_CPE_LOOKUP_URL=
SUNAT_LOOKUP_TOKEN=
SUNAT_REALTIME_GUARD_ENABLED=true
SUNAT_GUARD_BLOCK_ON_UNAVAILABLE=false
SUNAT_REALTIME_TIMEOUT_SECONDS=3
SUNAT_RUC=
SUNAT_SOL_USER=
SUNAT_SOL_PASSWORD=
SUNAT_XSD_DIR=
P12_CERT_PATH=
P12_CERT_PASSWORD=

# ── OpenTelemetry ─────────────────────────────────────────────
# Para deshabilitar (sin colector): dejar OTEL_SDK_DISABLED=true
OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
# Para habilitar con colector:
# OTEL_SDK_DISABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── RAG / pgvector ────────────────────────────────────────────
RAG_VECTOR_PROVIDER=pgvector
RAG_CORPUS_SOURCES=TUO_LIR,CODIGO_TRIBUTARIO,MANUAL_SUNAT,GUIA_INFRACCIONES,DL_728,DL_1057
RAG_EMBEDDING_DIMENSIONS=768
CHROMA_PERSIST_DIRECTORY=./.chroma
CHROMA_COLLECTION_NAME=contapro_legal_docs

# ── Integraciones ─────────────────────────────────────────────
BANK_API_BASE_URL=
ODOO_API_BASE_URL=
SAP_API_BASE_URL=
FEDEX_API_BASE_URL=
DHL_API_BASE_URL=
WHATSAPP_API_BASE_URL=

# ── Email SMTP ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ── Almacenamiento ────────────────────────────────────────────
S3_BUCKET=
SECRETS_MANAGER_URI=
